# ===========================================
# Observability.OS Environment Variables
# ===========================================

# MongoDB Connection String
# Format: mongodb://username:password@host:port/database
MONGO_URI="mongodb://127.0.0.1:27017/observability"

# JWT Secret for authentication tokens
# Generate a strong random string for production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server Port
PORT=5000

# ===========================================
# AI Provider Settings
# ===========================================

# Gemini API Key (for AI chat and analysis)
GEMINI_API_KEY=""

# Ollama runs on localhost:11434 by default (no config needed for local)

# ===========================================
# ServiceNow Integration
# ===========================================

# ServiceNow Instance URL
SERVICENOW_INSTANCE_URL="https://dev363754.service-now.com"

# ServiceNow Username (API user)
SERVICENOW_USER="admin"

# ServiceNow Password/API Key
SERVICENOW_PASSWORD=""

# ===========================================
# App Configuration
# ===========================================

# APP_URL: The URL where this app is hosted
APP_URL="http://localhost:3000"
